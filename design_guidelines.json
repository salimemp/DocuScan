  "instructions_to_main_agent": [
    "Use 'useColorScheme' from 'react-native' to detect theme.",
    "Implement a 'ThemeContext' or simple hook to supply current theme colors to components.",
    "Use 'StyleSheet.create' for all styles. Avoid inline styles where possible.",
    "For the 'Scan' button, use a large, high-contrast design with a shadow to make it the primary focal point.",
    "Use 'FlatList' for the History screen with 'numColumns' prop controlled by a state variable for Grid/List toggle.",
    "Use 'BlurView' from 'expo-blur' for the Tab Bar background if possible for a glass effect, or fallback to solid surface color.",
    "Ensure 'SafeAreaView' is used from 'react-native-safe-area-context'.",
    "All touchable elements must have 'activeOpacity={0.7}' or similar feedback.",
    "Add 'data-testid' to all interactive elements (buttons, inputs, list items)."
  ],
  "accessibility": {
    "contrast": "Ensure text colors meet AA standards against backgrounds.",
    "touch_targets": "Minimum 44x44px for all buttons.",
    "labels": "All IconButtons must have 'accessibilityLabel'."
  }
