  "layout_strategies": {
    "dashboard": {
      "structure": [
        "Header (Greeting + Date)",
        "Stats Row (2 columns)",
        "Action Area (Large Scan Button)",
        "Recent Scans (Horizontal Scroll + Section Header)"
      ],
      "spacing": "Gap 24px between sections"
    },
    "history": {
      "structure": [
        "Header (Title + Search Bar)",
        "Filter Row (Horizontal Scroll Chips)",
        "Content Area (FlatList - Grid/List Toggle)"
      ],
      "spacing": "Gap 16px"
    }
